// EPSILON Trading Simulator — Prisma Schema
// NextAuth v5 + Trading Models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth v5 Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  // Trading profile
  initialCapital Float    @default(100000.0)
  cash           Float    @default(100000.0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Trading relationships
  stocks      Stock[]
  trades      Trade[]
  orders      Order[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Trading Models ───────────────────────────────────────────────

model Stock {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  code      String
  name      String
  exchange  String   @default("US")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]
  orders Order[]

  @@unique([userId, code])
  @@index([userId])
  @@map("stocks")
}

model Trade {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  stockId     String   @map("stock_id")
  tradeDate   DateTime @map("trade_date")
  tradeType   String   @map("trade_type") // "buy" | "sell"
  shares      Int
  price       Float
  totalAmount Float    @map("total_amount")
  fee         Float    @default(0.0)
  createdAt   DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stockId])
  @@index([tradeDate])
  @@map("trades")
}

model Order {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  stockId      String    @map("stock_id")
  orderType    String    @map("order_type") // "market" | "limit" | "stop_loss" | "take_profit"
  side         String    // "buy" | "sell"
  shares       Int
  price        Float?
  triggerPrice Float?    @map("trigger_price")
  status       String    @default("pending") // "pending" | "filled" | "cancelled" | "rejected"
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("orders")
}
